# ============================================
# AREACAM Backend - Configuración de Entorno
# ============================================
# Este archivo contiene la configuración por defecto
# Copia este archivo a .env y ajusta según tu servidor

# ============================================
# CONFIGURACIÓN DEL SERVIDOR
# ============================================
# URL pública del servidor API
SERVER_IP=https://apicamaras.areagrupo.com
# Puerto donde escuchará el backend
PORT=4000
# Host (0.0.0.0 para aceptar conexiones externas)
HOST=0.0.0.0

# ============================================
# BASE DE DATOS MYSQL
# ============================================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=majesticflame
DB_PASSWORD=Flame2020
DB_NAME=ccio

# ============================================
# MEDIAMTX - URLs PARA STREAMING
# ============================================
# URL base para streaming HLS
HLS_BASE_URL=https://streamcamaras.areagrupo.com
# URL base para WebRTC
WEBRTC_BASE_URL=https://webrtccamaras.areagrupo.com
# URL base para RTSP
RTSP_BASE_URL=rtsp://rtspcamaras.areagrupo.com

# ============================================
# SEGURIDAD
# ============================================
# Clave secreta para JWT (cambiar en producción)
JWT_SECRET=areacam-secret-key-2024-production
# Tiempo de expiración de tokens
JWT_EXPIRES_IN=24h

# ============================================
# DETECCIÓN DE MOVIMIENTO
# ============================================
# Tipo de detector: opencv, simple, disabled
MOTION_DETECTOR_TYPE=opencv

# ============================================
# GRABACIONES
# ============================================
# Ruta donde se guardarán las grabaciones
RECORDINGS_PATH=/mnt/videos/areacam/recordings

# ============================================
# NOTIFICACIONES (OPCIONAL)
# ============================================
# Email para notificaciones
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu-email@gmail.com
# SMTP_PASS=tu-password
# SMTP_FROM=AREACAM <noreply@areacam.com>

# ============================================
# DESARROLLO/PRODUCCIÓN
# ============================================
NODE_ENV=production
# NODE_ENV=development
